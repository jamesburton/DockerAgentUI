{
  "id": "dotnet.test",
  "displayName": ".NET test",
  "category": "dotnet",
  "risk": 0,
  "exec": {
    "type": "command",
    "windows": { "file": "dotnet.exe", "args": ["test", "{projectOrSolution}"] },
    "linux": { "file": "dotnet", "args": ["test", "{projectOrSolution}"] }
  },
  "capabilities": ["filesystem", "process"],
  "constraints": {
    "maxSeconds": 1200,
    "allowNetwork": false,
    "allowFilesystemWrite": true,
    "requiresElevation": false,
    "workingDir": "{session.workdir}"
  }
}
