<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             x:Class="AgentHub.Maui.MainPage"
             Title="AgentHub">
  <VerticalStackLayout Padding="16" Spacing="12">
    <Label Text="Sessions" FontSize="22" />
    <Button Text="Refresh" Clicked="OnRefreshClicked"/>
    <CollectionView x:Name="SessionsList" SelectionMode="Single" SelectionChanged="OnSelectionChanged">
      <CollectionView.ItemTemplate>
        <DataTemplate>
          <Frame Padding="10">
            <VerticalStackLayout>
              <Label Text="{Binding SessionId}" FontAttributes="Bold"/>
              <Label Text="{Binding State}"/>
              <Label Text="{Binding Backend}"/>
            </VerticalStackLayout>
          </Frame>
        </DataTemplate>
      </CollectionView.ItemTemplate>
    </CollectionView>
    <Label Text="Live events" FontSize="18"/>
    <Editor x:Name="LogBox" AutoSize="TextChanges" HeightRequest="200" IsReadOnly="True"/>
  </VerticalStackLayout>
</ContentPage>
