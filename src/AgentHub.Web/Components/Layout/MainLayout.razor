@inherits LayoutComponentBase

<MudThemeProvider @ref="_themeProvider" Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">AgentHub Dashboard</MudText>
        <MudSpacer />
        <MudSwitch T="bool" Value="_isDarkMode" ValueChanged="ToggleDarkMode"
                   Color="Color.Primary" Label="Dark Mode" />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="pa-4" Style="margin-top: 64px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private MudThemeProvider _themeProvider = null!;
    private bool _isDarkMode = true;
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Surface = "#1e1e1e",
            Background = "#121212",
            AppbarBackground = "#1e1e1e",
            DrawerBackground = "#1a1a1a",
            Primary = "#569cd6",
            Secondary = "#dcdcaa"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode(bool value) => _isDarkMode = value;
}
