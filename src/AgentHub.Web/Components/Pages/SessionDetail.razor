@page "/session/{SessionId}"
@implements IDisposable
@inject DashboardApiClient Api
@inject SseStreamService SseStream
@inject NavigationManager Nav
@inject ISnackbar Snackbar

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Class="my-8" />
}
else if (_session is null)
{
    <MudAlert Severity="Severity.Error" Class="my-4">Session not found.</MudAlert>
    <MudButton Variant="Variant.Text" OnClick="@(() => Nav.NavigateTo("/"))">Back to Fleet</MudButton>
}
else
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudGrid>
            <MudItem xs="12" sm="6" md="2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Status</MudText>
                <MudChip T="string" Color="@GetStateColor(_session.State)" Size="Size.Small">
                    @_session.State.ToString()
                </MudChip>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Agent Type</MudText>
                <MudText>@_session.Backend</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Host</MudText>
                <MudText>@(_session.Node ?? "Unassigned")</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Duration</MudText>
                <MudText>@GetDuration()</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Started</MudText>
                <MudText>@_session.CreatedUtc.ToString("yyyy-MM-dd HH:mm:ss UTC")</MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <div class="d-flex gap-2 mb-4">
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo("/"))">
            Back to Fleet
        </MudButton>
        @if (_session.State is SessionState.Running or SessionState.Pending)
        {
            <MudButton Color="Color.Error" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Stop"
                       OnClick="StopSession">
                Stop Session
            </MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.HighlightOff"
                       OnClick="ForceStopSession">
                Force Stop
            </MudButton>
        }
    </div>

    @foreach (var approval in _pendingApprovals)
    {
        var capturedApproval = approval;
        <ApprovalAlert ApprovalEvent="capturedApproval"
                       OnResolved="@(new EventCallback<bool>(this, (bool result) => HandleApprovalResolved(capturedApproval, result)))" />
    }

    <TerminalOutput Events="_events" SessionId="@SessionId" />

    @if (_session.WorktreeBranch is not null)
    {
        <MudExpansionPanels Class="mt-4 mb-4" Elevation="1">
            <MudExpansionPanel Text="Diff Stats" IsExpandedChanged="OnDiffPanelExpanded">
                @if (_session.State is SessionState.Running or SessionState.Pending)
                {
                    <MudAlert Severity="Severity.Info" Class="my-2">Session still running -- diff stats available after completion.</MudAlert>
                }
                else if (_diffLoading)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="my-4" />
                }
                else if (_diffError is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="my-2">@_diffError</MudAlert>
                }
                else if (_diffStats is not null)
                {
                    <MudTable Items="_diffStats.Files" Dense="true" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh>File Path</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh Style="text-align:right">Insertions (+)</MudTh>
                            <MudTh Style="text-align:right">Deletions (-)</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Path</MudTd>
                            <MudTd>@context.Status</MudTd>
                            <MudTd Style="text-align:right">
                                <MudText Color="Color.Success">+@context.Insertions</MudText>
                            </MudTd>
                            <MudTd Style="text-align:right">
                                <MudText Color="Color.Error">-@context.Deletions</MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        @_diffStats.Summary
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="my-2" Color="Color.Default">Expand to load diff stats.</MudText>
                }
            </MudExpansionPanel>
        </MudExpansionPanels>
    }

    <MudPaper Class="pa-2 mt-2" Style="position: sticky; bottom: 0; z-index: 10;" Elevation="4">
        <MudStack Row AlignItems="AlignItems.Center">
            <MudTextField @bind-Value="_inputText"
                          Placeholder="Send input to session..."
                          Variant="Variant.Outlined"
                          Immediate="true"
                          OnKeyDown="OnInputKeyDown"
                          Disabled="_sending"
                          Class="flex-grow-1" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SendInput"
                       Disabled="@(string.IsNullOrWhiteSpace(_inputText) || _sending)">
                Send
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public string SessionId { get; set; } = string.Empty;

    private SessionSummary? _session;
    private readonly List<SessionEvent> _events = [];
    private readonly CancellationTokenSource _cts = new();
    private bool _loading = true;
    private readonly List<SessionEvent> _pendingApprovals = [];
    private string _inputText = "";
    private bool _sending;
    private readonly Queue<DateTimeOffset> _recentInputs = new();
    private const int RapidFireThreshold = 3;
    private static readonly TimeSpan RapidFireWindow = TimeSpan.FromSeconds(10);

    // Diff stats
    private DiffStats? _diffStats;
    private bool _diffLoading;
    private string? _diffError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _session = await Api.GetSessionAsync(SessionId, _cts.Token);
            if (_session is null)
            {
                _loading = false;
                return;
            }

            if (_session.State is SessionState.Running or SessionState.Pending)
            {
                var reader = SseStream.SubscribeSession(SessionId, _cts.Token);
                _ = Task.Run(async () =>
                {
                    try
                    {
                        await foreach (var evt in reader.ReadAllAsync(_cts.Token))
                        {
                            _events.Add(evt);
                            if (evt.Kind == SessionEventKind.ApprovalRequest)
                                _pendingApprovals.Add(evt);
                            if (evt.Kind == SessionEventKind.StateChanged)
                                _session = await Api.GetSessionAsync(SessionId, _cts.Token);
                            await InvokeAsync(StateHasChanged);
                        }
                    }
                    catch (OperationCanceledException) { }
                }, _cts.Token);
            }
            else
            {
                // Load history with pagination for completed sessions
                int page = 1;
                while (true)
                {
                    var (batch, totalCount) = await Api.GetSessionHistoryAsync(SessionId, page, 100, ct: _cts.Token);
                    _events.AddRange(batch);
                    if (batch.Count < 100 || _events.Count >= totalCount)
                        break;
                    page++;
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading session: {ex.Message}", Severity.Error);
        }

        _loading = false;
    }

    private async Task StopSession()
    {
        try
        {
            await Api.StopSessionAsync(SessionId, force: false, _cts.Token);
            Snackbar.Add("Session stop requested.", Severity.Success);
            _session = await Api.GetSessionAsync(SessionId, _cts.Token);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to stop session: {ex.Message}", Severity.Error);
        }
    }

    private async Task ForceStopSession()
    {
        try
        {
            await Api.StopSessionAsync(SessionId, force: true, _cts.Token);
            Snackbar.Add("Session force-stopped.", Severity.Success);
            _session = await Api.GetSessionAsync(SessionId, _cts.Token);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to force-stop session: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleApprovalResolved(SessionEvent evt, bool approved)
    {
        try
        {
            var approvalId = evt.Meta?.GetValueOrDefault("approvalId") ?? evt.Data;
            await Api.ResolveApprovalAsync(approvalId, approved, _cts.Token);
            _pendingApprovals.Remove(evt);
            Snackbar.Add($"Approval {(approved ? "granted" : "rejected")}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to resolve approval: {ex.Message}", Severity.Error);
        }
    }

    private async Task SendInput()
    {
        if (string.IsNullOrWhiteSpace(_inputText) || _sending) return;
        _sending = true;
        try
        {
            var delivered = await Api.SendInputAsync(SessionId!, _inputText, isFollowUp: true);
            _inputText = "";

            if (delivered)
                Snackbar.Add("Steering delivered", Severity.Success, c => c.VisibleStateDuration = 1500);
            else
                Snackbar.Add("Warning: Delivery unconfirmed", Severity.Warning, c => c.VisibleStateDuration = 3000);

            // Rapid-fire detection
            var now = DateTimeOffset.UtcNow;
            _recentInputs.Enqueue(now);
            while (_recentInputs.Count > 0 && now - _recentInputs.Peek() > RapidFireWindow)
                _recentInputs.Dequeue();
            if (_recentInputs.Count >= RapidFireThreshold)
                Snackbar.Add("Sending multiple commands rapidly -- agent may not process them in order", Severity.Warning, c => c.VisibleStateDuration = 3000);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _sending = false;
        }
    }

    private async Task OnInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_inputText))
            await SendInput();
    }

    private async Task OnDiffPanelExpanded(bool expanded)
    {
        if (!expanded) return;
        if (_diffStats is not null || _diffLoading) return;
        if (_session?.State is SessionState.Running or SessionState.Pending) return;

        _diffLoading = true;
        try
        {
            _diffStats = await Api.GetSessionDiffAsync(SessionId, _cts.Token);
            if (_diffStats is null)
                _diffError = "Could not load diff stats for this session.";
        }
        catch (Exception ex)
        {
            _diffError = ex.Message;
        }
        finally
        {
            _diffLoading = false;
        }
    }

    private string GetDuration()
    {
        var elapsed = DateTimeOffset.UtcNow - _session!.CreatedUtc;
        return elapsed.TotalHours >= 1
            ? $"{(int)elapsed.TotalHours}h {elapsed.Minutes}m"
            : $"{elapsed.Minutes}m {elapsed.Seconds}s";
    }

    private static Color GetStateColor(SessionState state) => state switch
    {
        SessionState.Running => Color.Success,
        SessionState.Pending => Color.Warning,
        SessionState.Stopped => Color.Default,
        SessionState.Failed => Color.Error,
        _ => Color.Default
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
